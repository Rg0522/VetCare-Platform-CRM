# =================================
# VETCARE PRODUCTION CONFIGURATION
# =================================

# Server Configuration
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://your-frontend-domain.com

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/vetcare-production

# JWT Secret
JWT_SECRET=your-super-secure-jwt-secret-key-for-production

# Admin Credentials
ADMIN_EMAIL=admin@vetcare.com
ADMIN_NAME=VetCare Administrator

# =================================
# FILE STORAGE CONFIGURATION
# =================================

# Storage Type: 'local', 'cloudinary', 's3'
STORAGE_TYPE=cloudinary

# Cloudinary Configuration (RECOMMENDED)
CLOUDINARY_CLOUD_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# AWS S3 Configuration (Alternative)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=vetcare-documents

# =================================
# PAYMENT GATEWAY
# =================================

# Razorpay Configuration
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-secret

# =================================
# VIDEO CALLING
# =================================

# Agora.io Configuration
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-certificate

# =================================
# PUSH NOTIFICATIONS
# =================================

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-firebase-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-firebase-private-key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_CLIENT_ID=your-firebase-client-id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# =================================
# EMAIL SERVICE
# =================================

# Gmail SMTP Configuration
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM="VetCare Platform <noreply@vetcare.com>"

# =================================
# RATE LIMITING
# =================================

RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=900000

# =================================
# SECURITY CONFIGURATION
# =================================

# CORS Origins (comma-separated)
CORS_ORIGINS=https://your-frontend-domain.com,https://admin.vetcare.com

# Document Upload Limits
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# =================================
# MONITORING & LOGGING
# =================================

# Error Monitoring (optional)
SENTRY_DSN=your-sentry-dsn

# Analytics (optional)
GOOGLE_ANALYTICS_ID=your-ga-id
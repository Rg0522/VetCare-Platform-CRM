# Database Configuration
MONGO_URI=mongodb://localhost:27017/vetcare
DB_NAME=vetcare

# JWT Secret (Generate a secure random string)
JWT_SECRET=your-super-secure-jwt-secret-key-here

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Email Configuration (Gmail)
EMAIL_USER=officialsatyam0777@gmail.com
EMAIL_PASS=your-gmail-app-password-here

# Email Configuration (Alternative - SendGrid)
# SENDGRID_API_KEY=your-sendgrid-api-key
# FROM_EMAIL=officialsatyam0777@gmail.com

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png,image/gif,application/pdf

# Socket.IO Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Admin Configuration
ADMIN_EMAIL=admin@vetcare.com
ADMIN_PASSWORD=admin123

# Features Flags
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_REAL_TIME_CHAT=true

# Third-party Services
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Payment Configuration (for future use)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
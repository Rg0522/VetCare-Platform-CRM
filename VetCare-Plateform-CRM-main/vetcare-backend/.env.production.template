# VetCare Production Environment Configuration
# SECURITY: ALL values must be changed for production deployment

# Server Configuration
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-domain.com

# Database Configuration (REQUIRED)
MONGODB_URI=mongodb+srv://your-username:your-password@cluster.mongodb.net/vetcare

# JWT Configuration (REQUIRED - Generate strong secret)
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_SECRET_MINIMUM_32_CHARACTERS_FOR_PRODUCTION
JWT_EXPIRE=24h

# Admin Configuration (REQUIRED)
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD

# Email Configuration (REQUIRED for notifications)
EMAIL_USER=noreply@your-domain.com
EMAIL_PASS=your-app-password
EMAIL_FROM=VetCare <noreply@your-domain.com>

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=1000

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# External Services (Optional)
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
FIREBASE_PROJECT_ID=your_firebase_project_id

# IMPORTANT SECURITY NOTES:
# 1. Generate a strong JWT_SECRET using: openssl rand -base64 32
# 2. Use a strong ADMIN_PASSWORD with uppercase, lowercase, numbers, and symbols
# 3. Configure proper SMTP settings for production email delivery
# 4. Set up SSL/TLS certificates for HTTPS
# 5. Enable firewall and rate limiting at server level
# 6. Regular security audits and dependency updates
# 7. Monitor logs for suspicious activity
